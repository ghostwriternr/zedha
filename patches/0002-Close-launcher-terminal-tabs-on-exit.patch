From 6371f4229b8c200b2b99569e9f952f70b2f15eb6 Mon Sep 17 00:00:00 2001
From: Naresh <ghostwriternr@gmail.com>
Date: Wed, 3 Jun 2026 02:22:35 +0100
Subject: [PATCH 2/2] Close launcher terminal tabs on exit

Allow launcher clients to request tab closure when the spawned task exits.

Pi and tmux remain responsible for execution and lifecycle. Zed only
cleans up the display tab after the tmux attach process exits.

diff --git a/crates/terminal_view/src/terminal_launcher.rs b/crates/terminal_view/src/terminal_launcher.rs
index 8ae4ca1292..8d9c8e2a60 100644
--- a/crates/terminal_view/src/terminal_launcher.rs
+++ b/crates/terminal_view/src/terminal_launcher.rs
@@ -15,7 +15,7 @@ use gpui::{AnyWindowHandle, App, AppContext as _, AsyncApp, Entity, Global, Task
 use itertools::Itertools as _;
 use net::async_net::{UnixListener, UnixStream};
 use serde::{Deserialize, Serialize};
-use task::{RevealStrategy, RevealTarget, SpawnInTerminal, TaskId};
+use task::{HideStrategy, RevealStrategy, RevealTarget, SpawnInTerminal, TaskId};
 use tempfile::TempDir;
 use uuid::Uuid;
 
@@ -335,6 +335,8 @@ pub struct TerminalLaunchRequest {
     #[serde(default)]
     pub env: HashMap<String, String>,
     pub label: Option<String>,
+    #[serde(default, rename = "closeOnExit")]
+    pub close_on_exit: bool,
 }
 
 pub fn parse_request(input: &str) -> Result<TerminalLaunchRequestEnvelope> {
@@ -361,6 +363,11 @@ pub fn request_to_task(request: TerminalLaunchRequest) -> SpawnInTerminal {
         allow_concurrent_runs: true,
         reveal: RevealStrategy::Always,
         reveal_target: RevealTarget::Dock,
+        hide: if request.close_on_exit {
+            HideStrategy::Always
+        } else {
+            HideStrategy::Never
+        },
         ..SpawnInTerminal::default()
     }
 }
@@ -407,6 +414,7 @@ mod tests {
                 cwd: Some(PathBuf::from("/tmp/project")),
                 env,
                 label: Some("Pi live terminal".to_string()),
+                close_on_exit: false,
             })
         );
     }
@@ -458,6 +466,7 @@ mod tests {
             cwd: Some(PathBuf::from("/tmp/project")),
             env: env.clone(),
             label: Some("Pi live terminal".to_string()),
+            close_on_exit: false,
         };
 
         let task = request_to_task(request);
@@ -476,6 +485,30 @@ mod tests {
         assert!(task.allow_concurrent_runs);
         assert_eq!(task.reveal_target, RevealTarget::Dock);
         assert_eq!(task.reveal, RevealStrategy::Always);
+        assert_eq!(task.hide, HideStrategy::Never);
+    }
+
+    #[test]
+    fn launch_request_can_close_terminal_when_task_exits() {
+        let request = parse_request(
+            r#"{
+                "id": 7,
+                "workspace": "workspace-a",
+                "method": "terminal.create",
+                "params": {
+                    "command": "tmux",
+                    "args": ["attach-session", "-t", "pi-live-123"],
+                    "label": "Pi live terminal",
+                    "closeOnExit": true
+                }
+            }"#,
+        )
+        .expect("terminal.create request should parse");
+        let TerminalLaunchMethod::Create(request) = request.method;
+
+        let task = request_to_task(request);
+
+        assert_eq!(task.hide, HideStrategy::Always);
     }
 
     async fn init_workspace_with_panel(
