+        cx.executor().allow_parking();
+        init_test(cx);
+
+        let (window_handle, terminal_panel) = init_workspace_with_panel(cx).await;
+        let mut registry = TerminalLauncherRegistry::default();
+        registry.register_workspace(
+            "workspace-a".to_string(),
+            window_handle.into(),
+            terminal_panel,
+        );
+        registry.unregister_workspace("workspace-a");
+
+        let request = parse_request(
+            r#"{"id":7,"workspace":"workspace-a","method":"terminal.create","params":{"command":"echo"}}"#,
+        )
+        .expect("terminal.create request should parse");
+        let error = cx
+            .update(|cx| registry.handle_request(request, cx))
+            .await
+            .expect_err("unregistered workspaces should be rejected");
+
+        assert!(
+            error
+                .to_string()
+                .contains("unknown terminal launcher workspace"),
+            "unexpected error: {error}"
+        );
+    }
+
+    #[gpui::test]
+    async fn registry_routes_create_by_workspace_token(cx: &mut TestAppContext) {
+        cx.executor().allow_parking();
+        init_test(cx);
+
+        let (window_handle, terminal_panel) = init_workspace_with_panel(cx).await;
+        let mut registry = TerminalLauncherRegistry::default();
+        registry.register_workspace(
+            "workspace-a".to_string(),
+            window_handle.into(),
+            terminal_panel.clone(),
+        );
+
+        let panel_items_before =
+            terminal_panel.read_with(cx, |panel, cx| panel.active_pane.read(cx).items_len());
+        let request = parse_request(
+            r#"{"id":7,"workspace":"workspace-a","method":"terminal.create","params":{"command":"echo","args":["hello"],"label":"Pi live terminal"}}"#,
+        )
+        .expect("terminal.create request should parse");
+
+        let response = cx
+            .update(|cx| registry.handle_request(request, cx))
+            .await
+            .expect("terminal launcher request should be routed");
+        cx.run_until_parked();
+
+        assert!(
+            matches!(response, TerminalLauncherResponse::Created { .. }),
+            "unexpected response: {response:?}"
+        );
+        let panel_items_after =
+            terminal_panel.read_with(cx, |panel, cx| panel.active_pane.read(cx).items_len());
+        assert_eq!(panel_items_after, panel_items_before + 1);
+    }
+
+    #[gpui::test]
+    async fn socket_handles_create_line(cx: &mut TestAppContext) {
+        cx.executor().allow_parking();
+        init_test(cx);
+
+        let (window_handle, terminal_panel) = init_workspace_with_panel(cx).await;
+        let mut registry = TerminalLauncherRegistry::default();
+        registry.register_workspace(
+            "workspace-a".to_string(),
+            window_handle.into(),
+            terminal_panel,
+        );
+        let server = cx
+            .update(|cx| TerminalLauncher::bind(registry, cx))
+            .expect("terminal launcher socket should bind");
+        let socket_path = server.socket_path().to_path_buf();
+
+        let response = cx
+            .update(|cx| {
+                cx.spawn(async move |_| {
+                    let mut stream = UnixStream::connect(socket_path).await?;
+                    stream
+                        .write_all(
+                            br#"{"id":7,"workspace":"workspace-a","method":"terminal.create","params":{"command":"echo","args":["hello"],"label":"Pi live terminal"}}
+"#,
+                        )
+                        .await?;
+                    let mut response = String::new();
+                    BufReader::new(stream).read_line(&mut response).await?;
+                    anyhow::Ok(response)
+                })
+            })
+            .await
+            .expect("socket should return a response line");
+
+        let response: serde_json::Value =
+            serde_json::from_str(response.trim_end()).expect("response should be valid JSON");
+        assert_eq!(response["id"], 7);
+        assert!(response["result"]["terminalId"].as_u64().is_some());
+    }
+
+    #[gpui::test]
+    async fn init_starts_global_socket_server(cx: &mut TestAppContext) {
+        cx.executor().allow_parking();
+        init_test(cx);
+
+        let socket_path = cx.update(|cx| {
+            TerminalLauncher::global(cx)
+                .expect("terminal launcher should be global")
+                .read(cx)
+                .socket_path()
+                .to_path_buf()
+        });
+
+        assert!(socket_path.exists());
+        let socket_dir = socket_path.parent().expect("socket should have parent dir");
+        assert!(
+            socket_dir
+                .file_name()
+                .and_then(|name| name.to_str())
+                .is_some_and(|name| name.starts_with("zed-terminal-launcher")),
+            "socket directory should use the terminal launcher tempfile prefix: {socket_dir:?}"
+        );
+        #[cfg(unix)]
+        {
+            use std::os::unix::fs::PermissionsExt as _;
+            assert_eq!(
+                std::fs::metadata(socket_dir)
+                    .expect("socket directory should exist")
+                    .permissions()
+                    .mode()
+                    & 0o777,
+                0o700,
+            );
+        }
+    }
+}
