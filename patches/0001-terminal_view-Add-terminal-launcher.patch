+        assert_eq!(task.full_label, "Pi live terminal");
+        assert_eq!(task.label, "Pi live terminal");
+        assert_eq!(task.command, Some("echo hello".to_string()));
+        assert_eq!(task.args, vec!["from-pi".to_string()]);
+        assert_eq!(task.cwd, Some(PathBuf::from("/tmp/project")));
+        assert_eq!(task.env, env);
+        assert!(task.use_new_terminal);
+        assert!(task.allow_concurrent_runs);
+        assert_eq!(task.reveal_target, RevealTarget::Dock);
+        assert_eq!(task.reveal, RevealStrategy::Always);
