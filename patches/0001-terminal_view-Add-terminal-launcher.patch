+use std::{
+    cell::RefCell,
+    io,
+    path::{Path, PathBuf},
+    rc::Rc,
+};
+
+use anyhow::{Result, anyhow};
+use collections::HashMap;
+use futures::{
+    AsyncBufReadExt, AsyncReadExt, AsyncWriteExt,
+    io::{AsyncBufRead, BufReader},
+};
+use gpui::{AnyWindowHandle, App, AppContext as _, AsyncApp, Entity, Global, Task, WeakEntity};
+use itertools::Itertools as _;
+use net::async_net::{UnixListener, UnixStream};
+use serde::{Deserialize, Serialize};
+use task::{RevealStrategy, RevealTarget, SpawnInTerminal, TaskId};
+use tempfile::TempDir;
+use uuid::Uuid;
+
+use crate::terminal_panel::TerminalPanel;
+
+const MAX_REQUEST_BYTES: usize = 64 * 1024;
+
+pub fn init(cx: &mut App) {
+    TerminalLauncher::init_global(cx);
+}
+
+pub fn global(cx: &App) -> Option<Entity<TerminalLauncher>> {
+    TerminalLauncher::global(cx)
+}
+
+pub fn new_workspace_token() -> String {
+    Uuid::new_v4().to_string()
+}
+
+pub fn register_workspace(
+    token: String,
+    window: AnyWindowHandle,
+    terminal_panel: Entity<TerminalPanel>,
+    cx: &mut App,
+) {
+    if let Some(launcher) = global(cx) {
+        launcher.update(cx, |launcher, _| {
+            launcher.register_workspace(token, window, terminal_panel)
+        });
+    }
+}
+
+pub fn unregister_workspace(token: &str, cx: &mut App) {
+    if let Some(launcher) = global(cx) {
+        launcher.update(cx, |launcher, _| launcher.unregister_workspace(token));
+    }
+}
+
+pub struct TerminalLauncher {
+    socket_path: PathBuf,
+    registry: Rc<RefCell<TerminalLauncherRegistry>>,
+    _socket_dir: TempDir,
+    _server_task: Task<()>,
+}
+
+struct GlobalTerminalLauncher(Entity<TerminalLauncher>);
+
+impl Global for GlobalTerminalLauncher {}
+
+impl TerminalLauncher {
+    fn init_global(cx: &mut App) {
+        if cx.try_global::<GlobalTerminalLauncher>().is_some() {
+            return;
+        }
+
+        match Self::bind(TerminalLauncherRegistry::default(), cx) {
+            Ok(launcher) => {
+                let launcher = cx.new(|_| launcher);
+                cx.set_global(GlobalTerminalLauncher(launcher));
+            }
+            Err(error) => {
+                log::debug!("failed to bind terminal launcher socket: {error}");
+            }
+        }
+    }
+
+    pub fn global(cx: &App) -> Option<Entity<Self>> {
+        cx.try_global::<GlobalTerminalLauncher>()
+            .map(|global| global.0.clone())
+    }
+
+    pub fn bind(registry: TerminalLauncherRegistry, cx: &mut App) -> Result<Self> {
+        let socket_dir = tempfile::Builder::new()
+            .prefix("zed-terminal-launcher")
+            .tempdir()?;
+        #[cfg(unix)]
+        {
+            use std::os::unix::fs::PermissionsExt as _;
+            std::fs::set_permissions(socket_dir.path(), std::fs::Permissions::from_mode(0o700))?;
+        }
+        let socket_path = socket_dir.path().join("terminal.sock");
+        let listener = UnixListener::bind(&socket_path)?;
+        let registry = Rc::new(RefCell::new(registry));
+        let server_task = cx.spawn({
+            let registry = registry.clone();
+            async move |cx| {
+                while let Ok((stream, _)) = listener.accept().await {
+                    Self::serve_connection(stream, registry.clone(), cx);
+                }
+            }
+        });
+
+        Ok(Self {
+            socket_path,
+            registry,
+            _socket_dir: socket_dir,
+            _server_task: server_task,
+        })
+    }
+
+    pub fn register_workspace(
+        &mut self,
+        token: String,
+        window: AnyWindowHandle,
+        terminal_panel: Entity<TerminalPanel>,
+    ) {
+        self.registry
+            .borrow_mut()
+            .register_workspace(token, window, terminal_panel);
+    }
+
+    pub fn unregister_workspace(&mut self, token: &str) {
+        self.registry.borrow_mut().unregister_workspace(token);
+    }
+
+    pub fn socket_path(&self) -> &Path {
+        &self.socket_path
+    }
+
+    fn serve_connection(
+        stream: UnixStream,
+        registry: Rc<RefCell<TerminalLauncherRegistry>>,
+        cx: &mut AsyncApp,
+    ) {
+        let (read, mut write) = stream.split();
+        cx.spawn(async move |cx| {
+            let mut reader = BufReader::new(read);
+            loop {
+                let line = match read_bounded_line(&mut reader).await {
+                    Ok(Some(line)) => line,
+                    Ok(None) => break,
+                    Err(error) => {
+                        log::debug!("failed to read terminal launcher request: {error}");
+                        break;
+                    }
+                };
+
+                let response = cx.update(|cx| registry.borrow().handle_json_line(&line, cx));
+                let response = match response.await {
+                    Ok(response) => response,
+                    Err(error) => {
+                        format!("{}\n", serde_json::json!({ "error": error.to_string() }))
+                    }
+                };
+                if let Err(error) = write.write_all(response.as_bytes()).await {
+                    log::debug!("failed to write terminal launcher response: {error}");
+                    break;
+                }
+            }
+        })
+        .detach();
+    }
+}
+
+async fn read_bounded_line<R>(reader: &mut R) -> io::Result<Option<String>>
+where
+    R: AsyncBufRead + Unpin,
+{
+    let mut line = Vec::new();
+    loop {
+        let available = reader.fill_buf().await?;
+        if available.is_empty() {
+            if line.is_empty() {
+                return Ok(None);
+            }
+            break;
+        }
+
+        let take_len = available
+            .iter()
+            .position(|byte| *byte == b'\n')
+            .map_or(available.len(), |position| position + 1);
+        if line.len().saturating_add(take_len) > MAX_REQUEST_BYTES {
+            return Err(io::Error::new(
+                io::ErrorKind::InvalidData,
+                "terminal launcher request exceeds maximum size",
+            ));
+        }
+        line.extend_from_slice(&available[..take_len]);
+        reader.consume_unpin(take_len);
+        if line.ends_with(b"\n") {
+            break;
+        }
+    }
+
+    String::from_utf8(line).map(Some).map_err(|error| {
+        io::Error::new(
+            io::ErrorKind::InvalidData,
+            format!("terminal launcher request was not valid UTF-8: {error}"),
+        )
+    })
+}
+
+#[derive(Default)]
+pub struct TerminalLauncherRegistry {
+    workspaces: HashMap<String, (AnyWindowHandle, WeakEntity<TerminalPanel>)>,
+}
+
+impl TerminalLauncherRegistry {
+    pub fn register_workspace(
+        &mut self,
+        token: String,
+        window: AnyWindowHandle,
+        terminal_panel: Entity<TerminalPanel>,
+    ) {
+        self.workspaces
+            .insert(token, (window, terminal_panel.downgrade()));
+    }
+
+    pub fn unregister_workspace(&mut self, token: &str) {
+        self.workspaces.remove(token);
+    }
+
+    pub fn handle_json_line(&self, line: &str, cx: &mut App) -> Task<Result<String>> {
+        let request = match parse_request(line) {
+            Ok(request) => request,
+            Err(error) => return Task::ready(Err(error)),
+        };
+        let request_id = request.id;
+        let response = self.handle_request(request, cx);
+        cx.spawn(async move |_| {
+            let response = response.await?;
+            let mut line = serde_json::to_string(&success_response(request_id, response))?;
+            line.push('\n');
+            Ok(line)
+        })
+    }
+
+    pub fn handle_request(
+        &self,
+        request: TerminalLaunchRequestEnvelope,
+        cx: &mut App,
+    ) -> Task<Result<TerminalLauncherResponse>> {
+        let Some((window_handle, terminal_panel)) =
+            self.workspaces.get(&request.workspace_token).cloned()
+        else {
+            return Task::ready(Err(anyhow!("unknown terminal launcher workspace")));
+        };
+
+        match request.method {
+            TerminalLaunchMethod::Create(request) => {
+                let task = cx.update_window(window_handle, |_, window, cx| {
+                    terminal_panel.update(cx, |terminal_panel, cx| {
+                        terminal_panel.spawn_terminal_launch_request(request, window, cx)
+                    })
+                });
+
+                match task {
+                    Ok(Ok(task)) => cx.spawn(async move |_| {
+                        let terminal = task.await?;
+                        Ok(TerminalLauncherResponse::Created {
+                            terminal_id: terminal.entity_id().as_u64(),
+                        })
+                    }),
+                    Ok(Err(error)) | Err(error) => Task::ready(Err(error)),
+                }
+            }
+        }
+    }
+}
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum TerminalLauncherResponse {
+    Created { terminal_id: u64 },
+}
+
+#[derive(Serialize)]
+pub struct TerminalLauncherSuccessResponse {
+    id: u64,
+    result: TerminalLauncherResponseResult,
+}
+
+#[derive(Serialize)]
+#[serde(untagged)]
+enum TerminalLauncherResponseResult {
+    Created {
+        #[serde(rename = "terminalId")]
+        terminal_id: u64,
+    },
+}
+
+pub fn success_response(
+    id: u64,
+    response: TerminalLauncherResponse,
+) -> TerminalLauncherSuccessResponse {
+    let result = match response {
+        TerminalLauncherResponse::Created { terminal_id } => {
+            TerminalLauncherResponseResult::Created { terminal_id }
+        }
+    };
+
+    TerminalLauncherSuccessResponse { id, result }
+}
+
+#[derive(Debug, Clone, PartialEq, Eq, Deserialize)]
+pub struct TerminalLaunchRequestEnvelope {
+    pub id: u64,
+    #[serde(rename = "workspace")]
+    pub workspace_token: String,
+    #[serde(flatten)]
+    pub method: TerminalLaunchMethod,
+}
+
+#[derive(Debug, Clone, PartialEq, Eq, Deserialize)]
+#[serde(tag = "method", content = "params")]
+pub enum TerminalLaunchMethod {
+    #[serde(rename = "terminal.create")]
+    Create(TerminalLaunchRequest),
+}
+
+#[derive(Debug, Clone, PartialEq, Eq, Deserialize)]
+pub struct TerminalLaunchRequest {
+    pub command: String,
+    #[serde(default)]
+    pub args: Vec<String>,
+    pub cwd: Option<PathBuf>,
+    #[serde(default)]
+    pub env: HashMap<String, String>,
+    pub label: Option<String>,
+}
+
+pub fn parse_request(input: &str) -> Result<TerminalLaunchRequestEnvelope> {
+    serde_json::from_str(input)
+        .map_err(|error| anyhow!("invalid terminal launcher request: {error}"))
+}
+
+pub fn request_to_task(request: TerminalLaunchRequest) -> SpawnInTerminal {
+    let label = request.label.unwrap_or_else(|| request.command.clone());
+    let command_label = std::iter::once(request.command.clone())
+        .chain(request.args.iter().cloned())
+        .join(" ");
+
+    SpawnInTerminal {
+        id: TaskId(format!("terminal-launcher:{label}")),
+        full_label: label.clone(),
+        label,
+        command: Some(request.command),
+        args: request.args,
+        command_label,
+        cwd: request.cwd,
+        env: request.env,
+        use_new_terminal: true,
+        allow_concurrent_runs: true,
+        reveal: RevealStrategy::Always,
+        reveal_target: RevealTarget::Dock,
+        ..SpawnInTerminal::default()
+    }
+}
+
