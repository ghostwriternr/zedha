+    #[gpui::test]
+    async fn bounded_line_reader_rejects_oversized_requests(_cx: &mut TestAppContext) {
+        let payload = vec![b'a'; MAX_REQUEST_BYTES + 1];
+        let mut reader = BufReader::new(futures::io::Cursor::new(payload));
+
+        let error = read_bounded_line(&mut reader)
+            .await
