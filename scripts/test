#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
source_dir=${1:-"$repo_root/.work/zed"}
test_command=${ZEDHA_TEST_COMMAND:-cargo test -p terminal_view terminal_launcher}

if [[ ! -d "$source_dir" ]]; then
  echo "source directory not found: $source_dir" >&2
  exit 1
fi

echo "Running Zedha validation in $source_dir"
(
  cd "$source_dir"
  bash -lc "$test_command"
)
