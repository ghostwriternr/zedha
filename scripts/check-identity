#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
source_dir=${1:-"$repo_root/.work/zed"}

if [[ ! -d "$source_dir" ]]; then
  echo "source directory not found: $source_dir" >&2
  exit 1
fi

assert_contains() {
  local file=$1
  local expected=$2
  if ! grep -Fq "$expected" "$source_dir/$file"; then
    echo "expected $file to contain: $expected" >&2
    exit 1
  fi
}

assert_not_contains() {
  local file=$1
  local unexpected=$2
  if grep -Fq "$unexpected" "$source_dir/$file"; then
    echo "expected $file not to contain: $unexpected" >&2
    exit 1
  fi
}

assert_contains crates/paths/src/paths.rs 'pub const APP_NAME: &str = "Zedha";'
assert_contains crates/release_channel/src/lib.rs 'ReleaseChannel::Dev => "Zedha"'
assert_contains crates/release_channel/src/lib.rs 'ReleaseChannel::Dev => "zedha"'
assert_contains crates/release_channel/src/lib.rs 'ReleaseChannel::Dev => "dev.naresh.Zedha"'
assert_contains crates/zed/Cargo.toml 'identifier = "dev.naresh.Zedha"'
assert_contains crates/zed/Cargo.toml 'name = "Zedha"'
assert_contains crates/zed/Cargo.toml 'osx_url_schemes = ["zedha"]'
assert_contains crates/client/src/client.rs 'pub const ZED_URL_SCHEME: &str = "zedha";'
assert_contains crates/cli/src/main.rs 'name = "zedha"'
assert_contains crates/install_cli/src/install_cli_binary.rs 'Path::new("/usr/local/bin/zedha")'
assert_not_contains crates/zed/Cargo.toml 'name = "Zed Dev"'

echo "Zedha identity checks passed"
